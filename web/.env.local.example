# Copy this to .env.local and fill in.

# URL of the SAHAYA backend (Cloud Run service URL or http://localhost:8080 in dev).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Google Maps Platform key — RESTRICT IT BY HTTP REFERRER in GCP Console
# (only allow requests from localhost:3000, your Vercel domain, etc.).
# Required APIs: Maps JavaScript API, Geocoding API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
