# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Where this backend is reachable (used to build /media/<id> URLs returned to the dashboard).
# Local dev: http://localhost:8080. Cloud Run: the service URL.
PUBLIC_BASE_URL=http://localhost:8080

# Gemini (Google AI Studio)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Maps Platform
# Enable: Maps JavaScript API, Geocoding API, Places API
GOOGLE_MAPS_API_KEY=

# Twilio (WhatsApp Sandbox)
# https://console.twilio.com/ → Messaging → Try it out → WhatsApp sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
