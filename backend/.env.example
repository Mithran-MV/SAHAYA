# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Public base URL (for Twilio webhook + media downloads)
# Local dev: ngrok URL; Cloud Run: the service URL
PUBLIC_BASE_URL=

# Gemini (Google AI Studio)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Firebase Admin SDK
# Path to service account JSON downloaded from Firebase console
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=

# Google Maps Platform
# Enable: Maps JavaScript API, Geocoding API, Places API
GOOGLE_MAPS_API_KEY=

# Twilio (WhatsApp Sandbox)
# https://console.twilio.com/ → Messaging → Try it out → Send a WhatsApp message
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
