rules_version = '2';

// Security rules for SAHAYA.
//
// Principle:
//   - Public read access to anonymized aggregates (needs, resolutions) so the
//     transparency dashboard works for any visitor.
//   - All writes flow through the Cloud Run backend using the Firebase Admin SDK,
//     which bypasses these rules. No client-side writes are permitted.
//   - Personally identifiable data (asha_workers, volunteers' phones) is never
//     readable by an unauthenticated client.

service cloud.firestore {
  match /databases/{database}/documents {

    // Anonymized community needs. The "reporter" sub-object contains only
    // a publicId and an optional first name, never a phone number.
    match /needs/{needId} {
      allow read: if true;
      allow write: if false;
    }

    // Volunteer impact logs. The volunteerId is opaque; phone is in `volunteers`.
    match /resolutions/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Volunteer roster: PII (phone). Backend-only.
    match /volunteers/{id} {
      allow read, write: if false;
    }

    // ASHA worker roster: PII (phone). Backend-only.
    match /asha_workers/{id} {
      allow read, write: if false;
    }

    // Aggregated daily stats for the dashboard hero strip.
    match /stats/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
